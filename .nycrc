{
  "all": true,
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/main.ts",
    "**/*.test.ts",
    "**/*.d.ts",
    "tests/**",
    "dist/**",
    "node_modules/**"
  ],
  "extension": [
    ".ts"
  ],
  "require": [
    "tsx/cjs"
  ],
  "reporter": [
    "text",
    "html",
    "lcov",
    "json"
  ],
  "temp-dir": ".nyc_output",
  "report-dir": "coverage",
  "check-coverage": false,
  "lines": 70,
  "functions": 70,
  "branches": 70,
  "statements": 70
}
