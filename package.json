{
  "name": "bank-transaction-system",
  "version": "1.0.0",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/src/main.js",
    "build": "rimraf dist && prisma generate && tsc",
    "clean": "rimraf dist",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "test": "nyc mocha --require tsx/cjs --exit 'tests/*.test.ts'",
    "test:watch": "mocha --require tsx/cjs --watch 'tests/**/*.test.ts'",
    "test:coverage": "nyc --reporter=html --reporter=text mocha --require tsx/cjs --exit 'tests/**/*.test.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "openapi-types": "^12.1.3",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.3",
    "chai": "^6.2.2",
    "cors": "^2.8.5",
    "mocha": "^11.7.5",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.1",
    "nyc": "^18.0.0",
    "prisma": "^7.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
